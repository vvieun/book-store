@startuml c4_l1
!include <C4/C4_Context>

title C4 L1 — Системный контекст: BookStore


Person(guest,     "Гость",         "Незарегистрированный посетитель.\nПросматривает каталог и отзывы.")
Person(customer,  "Покупатель",    "Зарегистрированный пользователь.\nПокупает книги, оставляет отзывы,\nполучает рекомендации.")
Person(moderator, "Модератор",     "Сотрудник платформы.\nМодерирует отзывы, редактирует каталог.")
Person(admin,     "Администратор", "Технический администратор.\nУправляет системой и пользователями.")

System(bookstore, "BookStore", "Книжный интернет-магазин\nс персонализированной\nрекомендательной системой.")

Rel(guest,     bookstore, "Просматривает каталог, ищет книги, читает отзывы")
Rel(customer,  bookstore, "Покупает книги, оставляет отзывы, получает рекомендации")
Rel(moderator, bookstore, "Модерирует контент, управляет каталогом")
Rel(admin,     bookstore, "Управляет пользователями, сбрасывает кэш, мониторит систему")

@enduml
