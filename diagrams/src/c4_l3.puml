@startuml c4_l3
!include <C4/C4_Component>

title C4 L3 — Components: Backend (Spring Boot REST API)


Container_Ext(spa,    "React SPA",    "React",          "Клиентское SPA-приложение")
ContainerDb_Ext(db,   "PostgreSQL",   "СУБД",           "Персистентное хранилище доменных данных")
ContainerDb_Ext(cache,"Redis",        "In-Memory Cache","Кэш рекомендаций")

Container_Boundary(api, "Spring Boot REST API") {

    Container_Boundary(layer_ctrl, "Controller Layer  [API Facades]") {
        Component(api_identity, "Identity Controllers", "Spring MVC @RestController", "AuthController, UserController: регистрация, вход, профиль; PATCH /api/users/{id}/role (только ADMIN).")
        Component(api_catalog,  "Catalog Controllers",  "Spring MVC @RestController", "BookController, ReviewController, RecommendationController, CollectionController, WishlistController.")
        Component(api_order,    "Order Controllers",    "Spring MVC @RestController", "OrderController: оформление заказов, список для персонала, смена статуса.")
    }

    Container_Boundary(layer_svc, "Service Layer  [Business Logic]") {
        Component(svc_identity, "Identity Services",    "Spring @Service", "AuthService, AuthSessionService, UserService: учётные данные, сессии по X-Auth-Token, смена роли.")
        Component(svc_catalog,  "Catalog Services",      "Spring @Service", "BookService, ReviewService, CollectionService, WishlistService: каталог, отзывы, подборки, список желаного.")
        Component(svc_orders,   "Order Service",         "Spring @Service", "OrderService: создание заказов, выборки, смена статуса для персонала.")
        Component(svc_reco,    "Recommendation Services", "Spring @Service", "RecommendationService и вспомогательные CF/CB, кэш рекомендаций в Redis.")
        Component(repo_iface,  "Repository Interfaces", "Java-интерфейсы", "BookRepository, ReviewRepository, UserRepository, OrderRepository, WishlistRepository, CollectionRepository, RecommendationCacheRepository (DIP).")
    }

    Container_Boundary(layer_repo, "Repository Layer  [Data Access — Repository]") {
        Component(repo, "Repository Implementations", "Spring Data JPA / Redis / Mongo", "Реализации репозиториев для PostgreSQL и MongoDB; кэш рекомендаций в Redis.")
    }
}

Rel(spa, api_identity, "HTTPS / JSON", "JSON по HTTPS, стиль REST")
Rel(spa, api_catalog,  "HTTPS / JSON", "JSON по HTTPS, стиль REST")
Rel(spa, api_order,    "HTTPS / JSON", "JSON по HTTPS, стиль REST")

Rel(api_identity, svc_identity, "uses", "вызывает")
Rel(api_catalog,  svc_catalog,  "uses", "вызывает")
Rel(api_catalog,  svc_reco,     "uses", "вызывает")
Rel(api_order,    svc_orders,   "uses", "вызывает")

Rel(svc_identity, repo_iface, "depends on", "абстракции репозиториев")
Rel(svc_catalog,  repo_iface, "depends on", "абстракции репозиториев")
Rel(svc_orders,   repo_iface, "depends on", "абстракции репозиториев")
Rel(svc_reco,     repo_iface, "depends on", "абстракции репозиториев")

Rel(repo, repo_iface, "implements", "реализация контрактов Spring Data")
Rel(repo, db,         "SQL via JPA", "запросы к PostgreSQL")
Rel(repo, cache, "recommendation cache", "кэш рекомендаций в Redis")

@enduml
